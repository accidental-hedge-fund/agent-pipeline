node_modules/
.pipeline-staging-*
*.log
.DS_Store
*.tgz

# Pipeline worktrees (created under .claude/worktrees/ by the worktree policy)
.claude/worktrees/

# Pipeline worktree_root (default: .worktrees per CLAUDE.md) — pipeline-created
# worktrees are never committed; without this, every /pipeline run on this repo
# dirties `main` and trips the doctor `worktree-clean` preflight.
.worktrees/

# Pipeline run artifacts (per-run evidence bundles written under .agent-pipeline/runs/).
# Runtime run output is local-only and must not be committed.
.agent-pipeline/runs/

# Pipeline roadmap artifacts (generated by `pipeline roadmap`; committed through a PR
# via `pipeline roadmap --apply`, never directly on main).
.agent-pipeline/roadmap/

# Per-issue evidence history (issue-<N>.jsonl) written by the engine; local-only,
# never committed.
.agent-pipeline/history/

# Stage-eval-runner experiment output (manifest/plan/runs/failures); local-only,
# never committed.
.agent-pipeline/evals/
